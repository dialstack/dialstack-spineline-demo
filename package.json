{
  "name": "dialstack-spineline-demo",
  "version": "0.1.1",
  "private": true,
  "scripts": {
    "dev": "FORCE_COLOR=1 next dev 2>&1 | pino-pretty -c -i pid,hostname -t HH:MM:ss",
    "build": "next build",
    "start": "next start",
    "start:migrate": "node scripts/migrate.mjs && next start",
    "migrate": "node --env-file=.env scripts/migrate.mjs",
    "migrate:up": "node --env-file=.env scripts/migrate.mjs up",
    "migrate:down": "node --env-file=.env scripts/migrate.mjs down",
    "migrate:create": "node-pg-migrate create",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "precommit": "npm run format && npm run lint && npm run typecheck",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@dialstack/sdk": "*",
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-radio-group": "^1.4.3",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.3",
    "@tailwindcss/postcss": "^4.3.2",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-query-devtools": "^5.101.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/pg": "^8.20.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.2.0",
    "libphonenumber-js": "^1.13.8",
    "lodash-es": "^4.18.1",
    "lucide-react": "^1.24.0",
    "next": "^16.2.10",
    "next-auth": "^4.24.14",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^12.0.4",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19",
    "baseline-browser-mapping": "^2.10.43",
    "eslint": "^10.7.0",
    "eslint-config-next": "^16.2.10",
    "postcss": "^8.5.19",
    "prettier": "^3.9.5",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=24"
  }
}
