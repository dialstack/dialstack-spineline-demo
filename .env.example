# Get your DialStack keys from https://docs.dialstack.ai
# Local dev: DIALSTACK_SECRET_KEY="sk_live_spineline"
DIALSTACK_SECRET_KEY="sk_INSERT_YOUR_SECRET_KEY"
# Local dev: DIALSTACK_PUBLIC_KEY="pk_live_spineline"
DIALSTACK_PUBLIC_KEY="pk_INSERT_YOUR_PUBLISHABLE_KEY"
DIALSTACK_WEBHOOK_SECRET="whsec_INSERT_YOUR_WEBHOOK_SECRET"

NEXT_PUBLIC_DIALSTACK_PUBLIC_KEY=$DIALSTACK_PUBLIC_KEY

# Local dev: NEXTAUTH_URL="http://localhost:$DS_SPINELINE_PORT"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your_nextauth_secret_key_here"

# Local dev: DIALSTACK_API_URL="http://127.0.0.1:$DS_API_MAIN_PORT"
# DIALSTACK_API_URL=

# Database Configuration
# Local dev: DATABASE_SECRET='{"username":"localdev","password":"localdev"}'
DATABASE_SECRET='{"username":"your_user","password":"your_password"}'
# Local dev: DB_HOST="localhost"
DB_HOST="localhost"
# Local dev: DB_PORT="$DS_POSTGRES_PORT"
DB_PORT="5432"
DB_NAME="spineline_db"
# Local dev: DB_SSL_ENABLED="false"

# Feature Flags
# Set to "true" to enable the onboarding demo section (disabled in production)
NEXT_PUBLIC_ENABLE_ONBOARDING="true"
